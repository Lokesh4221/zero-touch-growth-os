// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace    Workspace?
}

model Workspace {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName      String?
  businessType      String?
  targetAudience    String?
  location          String?
  productsServices  String?
  brandTone         String?
  usp               String?
  competitors       String?  // JSON string
  profileData       String?  // JSON string of AI-generated profile

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  campaigns         Campaign[]
  connectedAccounts ConnectedAccount[]
}

model Campaign {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String
  goal        String
  budget      String
  platform    String
  status      String   @default("draft") // draft | active | paused | completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ads         Ad[]
}

model Ad {
  id              String    @id @default(cuid())
  campaignId      String?
  campaign        Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  workspaceId     String

  headline        String
  primaryText     String
  cta             String
  caption         String?
  hook            String?
  bgGradient      String?
  accentColor     String?
  emoji           String?
  format          String?
  platform        String

  status          String    @default("draft") // draft | published | failed
  publishedPostId String?   // Real Meta post ID when published
  publishedAt     DateTime?

  estimatedCTR    String?
  estimatedROAS   String?

  impressions     Int       @default(0)
  clicks          Int       @default(0)
  reach           Int       @default(0)

  createdAt       DateTime  @default(now())
}

model ConnectedAccount {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  platform     String    // INSTAGRAM | FACEBOOK
  accountName  String
  accountId    String
  pageId       String?
  accessToken  String    // encrypted in production
  expiresAt    DateTime?
  isActive     Boolean   @default(true)

  createdAt    DateTime  @default(now())

  @@unique([workspaceId, platform])
}

